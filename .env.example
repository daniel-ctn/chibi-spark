# ChibiDrop — environment variables
#
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local` or any file matching `.env.*.local`.
#
# `NEXT_PUBLIC_*` variables are exposed to the browser. Everything else
# is server-only.

# ── Site ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Database (Neon Postgres) ────────────────────────────────────────────────
# Connection string from your Neon project. Use the pooled connection string
# in serverless/edge environments.
DATABASE_URL=""

# ── OpenAI ──────────────────────────────────────────────────────────────────
# API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=""
# Text model used for prompt expansion, metadata, and moderation.
# The model name is configurable so you can pin to whatever the SDK supports.
OPENAI_TEXT_MODEL="gpt-5.4-mini"
# Image model used for still chibi generation.
OPENAI_IMAGE_MODEL="gpt-image-1"

# ── Cloudflare R2 (object storage) ──────────────────────────────────────────
# S3-compatible credentials. Get them from the R2 dashboard → "Manage R2 API
# Tokens". The public bucket is served via `R2_PUBLIC_BASE_URL`.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="chibidrop-assets"
R2_PUBLIC_BASE_URL=""

# ── Animation provider ──────────────────────────────────────────────────────
# The default implementation calls Fal.ai. You can swap providers by
# changing the env vars below; the app code stays the same.
# Get a key from https://fal.ai/dashboard/keys
FAL_KEY=""
# Fal endpoint for the model you want to use (image-to-video).
FAL_ANIMATION_ENDPOINT="fal-ai/kling-video/v1.6/standard/image-to-video"
# How many of the 4 daily images get an animated variant (cost control).
ANIMATE_PER_BATCH="2"

# ── Upstash Redis (rate limiting) ───────────────────────────────────────────
# Create a Redis database at https://upstash.com and copy the REST credentials.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Cloudflare Turnstile (anti-bot on proposals) ─────────────────────────────
# Create a site at https://www.cloudflare.com/products/turnstile/
TURNSTILE_SECRET_KEY=""
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# ── Cron auth ───────────────────────────────────────────────────────────────
# Long random string. Vercel Cron sends this as `Authorization: Bearer ...`
# when calling the cron route.
CRON_SECRET=""
